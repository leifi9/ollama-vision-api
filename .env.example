# Ollama Vision API — environment template

# Runtime mode
ENV=production

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
VISION_MODEL=llava:7b

# Upload & storage
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=./uploads
DATABASE_PATH=~/.ollama-vision/gallery.db
PERSISTENT_UPLOAD_DIR=~/.ollama-vision/images
MAX_BATCH_SIZE=20

# CORS (JSON array for pydantic list parsing)
CORS_ORIGINS=["https://vision.example.com"]

# Optional API key protection for /api/* (except /api/health)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
API_KEY=

# Rate limits (SlowAPI format)
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_ANALYZE=30/minute
RATE_LIMIT_BATCH=10/minute
